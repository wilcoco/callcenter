# ----- Anthropic (Claude) -----
# 없으면 규칙 기반(rule-based) 폴백으로 동작합니다.
ANTHROPIC_API_KEY=
# 실시간 응대용(저지연) 모델 / 통화 분석용 모델
REPLY_MODEL=claude-haiku-4-5-20251001
ANALYSIS_MODEL=claude-sonnet-4-6

# ----- ClawOps (국내 070 번호 실시간 음성봇 — 권장) -----
# https://claw-ops.com 가입 후 발급. 셋 다 채우면 음성봇이 활성화됩니다.
CLAWOPS_API_KEY=
CLAWOPS_ACCOUNT_ID=
CLAWOPS_FROM_NUMBER=

# 음성 처리 방식 (둘 중 하나만 준비하면 됨):
#  A. OpenAI Realtime (간단 — 키 1개): OPENAI_API_KEY만 채우면 자동 선택
OPENAI_API_KEY=
# Realtime 모델/음성 변경 (한국어 인식이 아쉬우면 다른 모델 시도)
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
#  B. 파이프라인 (Deepgram STT + Claude + ElevenLabs TTS — 키 2개 추가):
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=uyVNoMrnUku1dZyVEXwD
# Deepgram STT 모델 (한국어: nova-3 기본, nova-2 대안)
DEEPGRAM_MODEL=nova-3
# 강제 지정하려면: realtime | pipeline (비우면 자동)
CLAWOPS_SESSION=
# (선택) 콘솔에 webhook을 등록한 경우 서명 검증용 signing key
CLAWOPS_SIGNING_KEY=

# ----- Twilio (해외 번호용 — 선택) -----
# 인바운드 webhook 서명 검증에 사용. 비워두면 검증을 건너뜁니다(로컬/테스트).
TWILIO_AUTH_TOKEN=
# 통화 안내/응대에 사용할 언어/음성
VOICE_LANGUAGE=ko-KR
TWILIO_VOICE=Polly.Seoyeon

# ----- App -----
DATABASE_URL=sqlite:///./data/callcenter.db
# AI 상담원이 참고할 회사 지식 문서 폴더. .md/.txt 파일을 넣으면 전부 읽음.
# 파일 추가/수정 시 재시작 없이 다음 통화부터 즉시 반영.
KNOWLEDGE_DIR=./knowledge
# (하위호환) 단일 파일 경로도 지원
KNOWLEDGE_FILE=./knowledge.md
# 공개 URL(ngrok 등). TwiML action 콜백 절대경로가 필요할 때 사용.
PUBLIC_BASE_URL=
# 한 통화당 최대 대화 턴 수(무한루프 방지)
MAX_TURNS=8
